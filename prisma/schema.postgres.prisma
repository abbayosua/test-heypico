// Prisma Schema for AI Map Assistant - PostgreSQL (Vercel/Neon Production)
// Use this schema when deploying to Vercel with Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CONVERSATION & MESSAGES ============

model Conversation {
  id        String    @id @default(cuid())
  sessionId String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  settings  SessionSettings?

  @@index([sessionId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String       @db.Text
  placesData     String?      @db.Text // JSON: extracted places
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ============ USER SETTINGS ============

model SessionSettings {
  id             String       @id @default(cuid())
  sessionId      String       @unique
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  llmProvider    String       @default("llm7") // "ollama" | "gemini" | "llm7"
  ollamaModel    String?
  geminiModel    String?
  geminiApiKey   String?      @db.Text // User's Gemini API key (optional)
  llm7Model      String?
  llm7ApiKey     String?      @db.Text // User's LLM7 API key (optional)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("session_settings")
}

// ============ CACHING ============

model SearchCache {
  id        String   @id @default(cuid())
  queryHash String   @unique
  query     String   @db.Text
  response  String   @db.Text
  places    String   @db.Text // JSON: Google Places results
  provider  String
  createdAt DateTime @default(now())
  expiresAt DateTime // TTL for cache invalidation

  @@index([expiresAt])
  @@map("search_cache")
}

// ============ USAGE LOGGING ============

model ApiUsageLog {
  id        String   @id @default(cuid())
  apiType   String   // "places" | "geocode" | "directions" | "llm"
  provider  String?  // "ollama" | "gemini" | "llm7" | "google"
  sessionId String?
  costUnits Int      @default(1)
  createdAt DateTime @default(now())

  @@index([apiType, createdAt])
  @@map("api_usage_logs")
}
